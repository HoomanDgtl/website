---

---

<section class="bg-[#0d0d0e] px-6 py-20 md:px-5 md:py-[120px] xl:px-[160px]">
  <div class="mx-auto max-w-[1397px]">
    <div class="mb-12 flex flex-col items-center gap-3 md:mb-14">
      <h2
        class="text-center text-[28px] font-medium text-white md:text-[40px] md:leading-tight"
      >
        The Infrastructure for AI & Data
      </h2>
      <p class="text-center text-base text-[#8c8e91] md:text-lg md:text-white">
        Train, deploy, and scale on the world's most cost-effective
        decentralized cloud.
      </p>
    </div>

    <div class="flex flex-col gap-5 md:gap-10">
      <!-- Row 1 -->
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-10">
        <!-- Train 3x Longer -->
        <div
          class="group relative flex min-h-[360px] flex-col justify-end overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] md:min-h-[406px]"
        >
          <img
            src="/images/home/1.png"
            alt="GPU workload visualization"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="relative z-10 flex flex-col gap-5 p-6 md:p-8">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              Train 3x Longer
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed">
              <span class="text-white">
                H100s for $1.33/hr vs AWS at $3.93/hr.
              </span>
              <span class="text-[#8c8e91]">
                Get nearly 3 hours of compute for the price of 1. Transparent
                pricing, no hidden fees.
              </span>
            </p>
          </div>
        </div>

        <!-- Ray Distributed Clusters -->
        <div
          class="group relative flex min-h-[360px] flex-col justify-end overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] md:min-h-[406px]"
        >
          <img
            src="/images/home/2.png"
            alt="Ray distributed clusters visualization"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="relative z-10 flex flex-col gap-5 p-6 md:p-8">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              Ray Distributed Clusters
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed">
              <span class="text-white">Scale training instantly.</span>
              <span class="text-[#8c8e91]">
                Spin up multi-node Ray clusters to train and fine-tune massive
                models without the DevOps headache.
              </span>
            </p>
          </div>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-10">
        <!-- 1-Click Templates -->
        <div
          class="group relative flex min-h-[360px] flex-col justify-end overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] md:min-h-[406px]"
        >
          <img
            src="/images/home/3.png"
            alt="1-click template deployment"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="relative z-10 flex flex-col gap-5 p-6 md:p-8">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              1-Click Templates
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed">
              <span class="text-white">Deploy faster.</span>
              <span class="text-[#8c8e91]">
                Launch pre-configured environments for Llama 3, Mistral, and
                Stable Diffusion in seconds.
              </span>
            </p>
          </div>
        </div>

        <!-- Docker Native -->
        <div
          class="group relative flex min-h-[360px] flex-col justify-end overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] md:min-h-[406px]"
        >
          <img
            src="/images/home/4.png"
            alt="Docker native container support"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="relative z-10 flex flex-col gap-5 p-6 md:p-8">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              Docker Native
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed">
              <span class="text-white">No refactoring.</span>
              <span class="text-[#8c8e91]">
                If it runs in a container, it runs on Akash. Full Kubernetes
                support with zero vendor lock-in.
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

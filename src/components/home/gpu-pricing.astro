<style>
  .counter-shadow {
    box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
  }
  .gpu-tab-shadow {
    box-shadow: 0px 1px 5px rgba(0, 0, 0, 0.06);
  }
</style>

<script type="module" define:vars={{ akashPrices, staticPrices }}>

let gpu = "H200"
let gpuCount = 1
let hours = 1

const priceAkash = document.getElementById("price-akash")
const savePercent = document.getElementById("save-percent")

const barAkash = document.getElementById("bar-akash")
const barAws = document.getElementById("bar-aws")
const barGcp = document.getElementById("bar-gcp")
const priceGcp = document.getElementById("price-gcp")
const priceCore = document.getElementById("price-core")
const priceAWS = document.getElementById("price-aws")
const barCore = document.getElementById("bar-core")

const gpuCountEl = document.getElementById("gpu-count")
const hourCountEl = document.getElementById("hour-count")

const gpuInc = document.getElementById("gpu-inc")
const gpuDec = document.getElementById("gpu-dec")
const hourInc = document.getElementById("hour-inc")
const hourDec = document.getElementById("hour-dec")

const tabs = document.querySelectorAll(".gpu-tab")

function update() {

const akash = akashPrices[gpu] || 0
const aws = staticPrices[gpu].aws
const gcp = staticPrices[gpu].gcp
const core = staticPrices[gpu].coreweave

const totalAkash = akash * gpuCount * hours
const totalAws = aws * gpuCount * hours
const totalGcp = gcp * gpuCount * hours
const totalCore = core * gpuCount * hours

const unit = hours === 1 ? 'hr' : `${hours}hrs`;

const maxCompetitor = Math.max(totalAws, totalGcp, totalCore)
const baseWidth = 70
const scale = baseWidth / maxCompetitor

let akashWidth = totalAkash * scale
let awsWidth = totalAws * scale
let gcpWidth = totalGcp * scale
let coreWidth = totalCore * scale

const MIN_BAR = 8

akashWidth = Math.max(akashWidth, MIN_BAR)
awsWidth = Math.max(awsWidth, MIN_BAR)
gcpWidth = Math.max(gcpWidth, MIN_BAR)
coreWidth = Math.max(coreWidth, MIN_BAR)

priceAkash.textContent = `$${totalAkash.toFixed(2)}/${unit}`
priceAWS.textContent = `$${totalAws.toFixed(2)}/${unit}`
priceGcp.textContent = `$${totalGcp.toFixed(2)}/${unit}`
priceCore.textContent = `$${totalCore.toFixed(2)}/${unit}`

barAkash.style.width = akashWidth + "%"
barAws.style.width = awsWidth + "%"
barGcp.style.width = gcpWidth + "%"
barCore.style.width = coreWidth + "%"

const minOther = Math.min(totalAws, totalGcp, totalCore)
const save = ((minOther - totalAkash) / minOther) * 100
savePercent.textContent = `Save ${save.toFixed(0)}%`

}

update()

tabs.forEach(tab => {

tab.addEventListener("click", () => {

tabs.forEach(t => {
  t.classList.remove("bg-white","gpu-tab-shadow","text-[#1D1D1F]")
  t.classList.add("text-[#86868B]")
})

tab.classList.add("bg-white","gpu-tab-shadow","text-[#1D1D1F]")
tab.classList.remove("text-[#86868B]")

gpu = tab.dataset.gpu
update()

})

})

gpuInc.addEventListener("click", () => {
gpuCount++
gpuCountEl.textContent = gpuCount
update()
})

gpuDec.addEventListener("click", () => {
if (gpuCount > 1) {
gpuCount--
gpuCountEl.textContent = gpuCount
update()
}
})

hourInc.addEventListener("click", () => {
hours++
hourCountEl.textContent = hours + "h"
update()
})

hourDec.addEventListener("click", () => {
if (hours > 1) {
hours--
hourCountEl.textContent = hours + "h"
update()
}
})

</script>
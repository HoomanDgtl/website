---
import TryAkashForm from "@/components/ui/try-akash-form";
import type { CollectionEntry } from "astro:content";
import clsx from "clsx";
import { ArrowRight, Award, Info } from "lucide-react";
import Slider from "./slider.astro";

interface Props {
  heroSection: CollectionEntry<"Homepage">["data"]["heroSection"];
}

const { heroSection } = Astro.props;
const pathname = Astro.url.pathname;

const tiles = [
  {
    title: "Deploy AI models<br />on AkashML",
    description: "Run AI Inference models on a high-performance managed API.",
    image: "/images/heroNew1.png",
  },
  {
    title: "Browse Templates on<br />Akash Console",
    description:
      "Explore pre-configured environments for Llama-3, DeepSeek, and more.",
    image: "/images/heroNew1.png",
  },
  {
    title: "Become an<br />Akash Provider",
    description: "Monetize your servers by joining the network.",
    image: "/images/heroNew1.png",
  },
];

---

<section class="relative overflow-hidden dark:bg-[#030303]">
  <!-- <div class="glow"></div> -->
  <div class="container relative z-[2] pt-16 md:pt-20">
    {
      pathname.includes("meetingconfirmation") && (
        <div class="relative mx-auto mt-10 flex w-fit items-center justify-center gap-2  rounded-lg border !border-primary px-4 py-3 text-sm text-primary">
          <Info className="size-4 shrink-0" />
          Thanks for booking your meeting, we look forward to speaking with you!
        </div>
      )
    }
    <h1
      class={clsx(
        "mx-auto text-center font-instrument text-[54px] font-normal leading-[1] tracking-[-0.88px] lg:text-[88px]",
        pathname.includes("meetingconfirmation") ? "mt-7" : "mt-10"
      )}
      set:html={heroSection.title}
    />

    <p
      class="mx-auto mt-4 text-center text-base md:text-xl"
      set:html={heroSection.description}
    />

    <div class="mt-12 flex flex-col justify-center gap-4">
      <div
        class="mx-auto flex items-center gap-2 rounded-full border bg-background2 px-6 py-2.5 text-center text-sm dark:bg-[#242429]/45 md:py-3 md:text-base"
      >
        <span>💸</span>
        <p class="text-[#8C8E91]">Get up to $500 in GPU credits</p>
      </div>
      <div class="flex justify-center">
        <TryAkashForm client:load type="hero" />
      </div>
    </div>

    <div class="mt-12 md:mt-16">
      <div class="mx-auto max-w-[1440px] xl:px-0">
        <div class="mx-auto max-w-[960px] pb-6 pt-6 md:pt-8">
          <div
            class="flex flex-col gap-5 md:flex-row md:items-start"
            id="hero-product-tiles"
          >
            {
              tiles.map((tile, i) => (
                <div class="flex flex-1 flex-col">
                  <div class="w-full px-5 md:px-0">
                    <Slider
                      tileIndex={i}
                      title={tile.title}
                      description={tile.description}
                    />
                  </div>

                  {/* Mobile: progress bar + image below each card (only visible when active) */}
                  <div class="hero-mobile-block pl-5 md:hidden">
                    <div class="hero-mobile-line relative">
                      <div class="h-px w-full bg-white/20" />
                      <div
                        class="hero-progress hero-progress-mobile absolute left-0 right-5 top-0 h-px bg-primary"
                        data-tile={i}
                      />
                    </div>
                    <div
                      class="hero-mobile-image overflow-hidden pl-4 pt-4"
                      data-tile={i}
                    >
                      <img
                        src={tile.image}
                        alt=""
                        class="h-[350px] w-full  rounded-tl-2xl object-cover object-left-top"
                      />
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          {/* Desktop: progress bars */}
          <div class="mt-5 hidden gap-5 px-1 md:flex">
            {
              tiles.map((_, i) => (
                <div class="relative flex-1">
                  <div class="h-px w-full bg-white/20" />
                  <div
                    class={`hero-progress hero-progress-desktop absolute left-0 top-0 h-px bg-primary ${i > 0 ? "w-0" : ""}`}
                    data-tile={i}
                  />
                </div>
              ))
            }
          </div>
        </div>
      </div>

      {/* Desktop: image container */}
      <div class="hidden md:block">
        <div
          class="mx-auto max-w-[1136px] rounded-t-3xl px-4 pb-0 pt-4"
        >
          {
            tiles.map((tile, i) => (
              <img
                src={tile.image}
                alt=""
                class={`hero-desktop-image w-full ${i > 0 ? "hidden" : ""}`}
                data-tile={i}
              />
            ))
          }
        </div>
      </div>
    </div>
    
  </div>
</section>

<style>
  @keyframes heroProgressFill {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }

  .hero-progress.active {
    animation: heroProgressFill 5s linear forwards;
  }

  .hero-progress.completed {
    width: 100%;
    animation: none;
  }

  .hero-tile[data-active="true"] .hero-icon-arrow {
    display: block;
  }
  .hero-tile[data-active="true"] .hero-icon-chevron {
    display: none;
  }
  .hero-tile:not([data-active="true"]) .hero-icon-arrow {
    display: none;
  }
  .hero-tile:not([data-active="true"]) .hero-icon-chevron {
    display: block;
  }

  /* Mobile block: hidden by default, shown when active */
  .hero-mobile-block {
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    overflow: hidden;
    transition:
      max-height 0.4s ease,
      opacity 0.3s ease,
      margin-top 0.3s ease;
  }

  .hero-mobile-block.active {
    max-height: 700px;
    opacity: 1;
    margin-top: 0.75rem;
  }

  .hero-mobile-image {
    margin-top: 1rem;
  }
</style>

<script>
  const TILE_COUNT = 3;
  let current = 0;
  let paused = false;

  const tiles = document.querySelectorAll<HTMLButtonElement>(".hero-tile");
  const desktopBars = document.querySelectorAll<HTMLElement>(
    ".hero-progress-desktop",
  );
  const mobileBars = document.querySelectorAll<HTMLElement>(
    ".hero-progress-mobile",
  );
  const desktopImages = document.querySelectorAll<HTMLElement>(
    ".hero-desktop-image",
  );
  const mobileBlocks =
    document.querySelectorAll<HTMLElement>(".hero-mobile-block");

  function activate(index: number) {
    current = index;

    tiles.forEach((tile, i) => {
      const isActive = i === index;
      tile.dataset.active = isActive ? "true" : "";

      if (isActive) {
        tile.classList.replace("border-white/10", "border-white/20");
        tile.classList.replace("bg-[#1b1b1d]", "bg-[#29292b]");
        tile.classList.remove("md:mt-3");
        tile
          .querySelector(".hero-tile-title")
          ?.classList.replace("text-[#86868b]", "text-currentColor");
      } else {
        tile.classList.replace("border-white/20", "border-white/10");
        tile.classList.replace("bg-[#29292b]", "bg-[#1b1b1d]");
        tile.classList.add("md:mt-3");
        tile
          .querySelector(".hero-tile-title")
          ?.classList.replace("text-white", "text-[#86868b]");
      }
    });

    // Desktop progress bars
    desktopBars.forEach((bar, i) => {
      bar.classList.remove("active", "completed");
      bar.style.width = "";
      bar.style.animationPlayState = paused ? "paused" : "running";

      if (i < index) {
        bar.classList.add("completed");
      } else if (i === index) {
        void bar.offsetWidth;
        bar.classList.add("active");
      } else {
        bar.style.width = "0%";
      }
    });

    // Mobile progress bars
    mobileBars.forEach((bar, i) => {
      bar.classList.remove("active", "completed");
      bar.style.width = "";
      bar.style.animationPlayState = paused ? "paused" : "running";

      if (i < index) {
        bar.classList.add("completed");
      } else if (i === index) {
        void bar.offsetWidth;
        bar.classList.add("active");
      } else {
        bar.style.width = "0%";
      }
    });

    // Desktop images
    desktopImages.forEach((img, i) => {
      if (i === index) {
        img.classList.remove("hidden");
      } else {
        img.classList.add("hidden");
      }
    });

    // Mobile blocks (line + image) — show only the active tile's
    mobileBlocks.forEach((block, i) => {
      if (i === index) {
        block.classList.add("active");
      } else {
        block.classList.remove("active");
      }
    });
  }

  // Only advance from whichever progress bar set is currently visible
  [...desktopBars, ...mobileBars].forEach((bar) => {
    bar.addEventListener("animationend", () => {
      if (!paused && bar.offsetParent !== null) {
        activate((current + 1) % TILE_COUNT);
      }
    });
  });

  tiles.forEach((tile, i) => {
    tile.addEventListener("click", () => {
      activate(i);
    });
  });

  const section = document.querySelector("#hero-product-tiles")!;
  section.addEventListener("mouseenter", () => {
    paused = true;
    [...desktopBars, ...mobileBars].forEach((bar) => {
      bar.style.animationPlayState = "paused";
    });
  });
  section.addEventListener("mouseleave", () => {
    paused = false;
    [...desktopBars, ...mobileBars].forEach((bar) => {
      bar.style.animationPlayState = "running";
    });
  });

  // Re-activate on resize so desktop/mobile bars stay in sync
  let resizeTimer: number;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      activate(current);
    }, 200);
  });

  activate(0);
</script>
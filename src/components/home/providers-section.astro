---
import axios from "axios"
import { BASE_API_URL } from "@/lib/constants"
import Globe from "@/components/home/providers-globe/globe"

const API = `${BASE_API_URL}/v1/providers`

let providers = []

try {
  const res = await axios.get(API)
  providers = res.data
} catch (e) {
  console.error(e)
}

type GlobeProvider = {
  id: string
  lat: number
  lng: number
  name: string
  region?: string
  country?: string
  uptime: number
  leases: number
  cpu: { active: number; total: number }
  gpu: { active: number; total: number }
  memory: { active: number; total: number }
  audited: boolean
}

const globeProviders: GlobeProvider[] = providers
  .filter(p => p.ipLat && p.ipLon)
  .map(p => ({
    id: p.owner,
    lat: Number(p.ipLat),
    lng: Number(p.ipLon),
    name: p.organization || p.owner.slice(0, 10),

    region: p.ipRegion,
    country: p.ipCountry,

    uptime: p.uptime30d ?? 0,
    leases: p.leaseCount ?? 0,

    cpu: {
      active: p.stats?.cpu?.active ?? 0,
      total: p.stats?.cpu?.total ?? 0
    },

    gpu: {
      active: p.stats?.gpu?.active ?? 0,
      total: p.stats?.gpu?.total ?? 0
    },

    memory: {
      active: p.stats?.memory?.active ?? 0,
      total: p.stats?.memory?.total ?? 0
    },

    audited: p.isAudited ?? false
  }))

const firstProvider = globeProviders[0]

const totalLeases = globeProviders.reduce((s, p) => s + p.leases, 0)
const totalCPU = globeProviders.reduce((s, p) => s + p.cpu.total, 0)
const totalGPU = globeProviders.reduce((s, p) => s + p.gpu.total, 0)
const totalMemoryBytes = globeProviders.reduce((s, p) => s + p.memory.total, 0)
const totalMemoryTB = (totalMemoryBytes / 1024 / 1024 / 1024 / 1024).toFixed(1)
---

<section class="container-nav-3 py-20 lg:py-[120px] text-white">

<h2 class="text-[32px] md:text-4xl lg:text-[40px] font-medium">
Global Grid. No Off Switch.
</h2>

<p class="text-[#86868B] mt-3 max-w-[680px]">
Access a permissionless grid of providers spanning 24 countries.
While centralized clouds have outages, the Supercloud has resilience.
</p>

<div class="mt-[60px] flex justify-between border-b border-[#39393B] pb-6 text-[#86868B] font-jetBrainsMono">
  <span>Active Leases: {totalLeases}</span>
  <span>Memory: {totalMemoryTB} TB</span>
  <span>CPUs: {totalCPU}</span>
  <span>Total GPUs: {totalGPU}</span>
</div>

<div class="grid lg:grid-cols-[1fr_360px] gap-12 mt-[60px] items-center max-w-6xl mx-auto">

<!-- Globe -->
<div class="relative h-[450px] max-w-[740px] overflow-hidden bg-[#0e0e0e]">
  <Globe
    client:only="react"
    providers={globeProviders}
    selectedId={firstProvider?.id}
    onSelect={(id) => {
      window.dispatchEvent(new CustomEvent("provider-select", { detail: id }))
    }}
  />
</div>

<!-- Provider Card -->
<div class="bg-gradient-to-b from-[#1f1f22] to-[#1a1a1c] border border-white/10 rounded-2xl p-7">

<div class="flex justify-between mb-5">
  <div>
    <p class="text-xs text-[#8A8F98]">Provider</p>
    <p id="provider-name" class="text-lg mt-1"></p>
  </div>

  <span id="provider-audited" class="bg-[#9EF29E] text-[#0c3205] px-4 py-1 rounded-full text-xs flex items-center gap-1">
    Audited
  </span>
</div>

<div class="flex flex-col gap-3 text-sm">

<div class="grid grid-cols-[90px_1fr] items-center gap-3">
<span class="text-[#8A8F98]">Location</span>
<div id="provider-location" class="bg-[#232326] border border-white/10 rounded-lg px-3 py-2"></div>
</div>

<div class="grid grid-cols-[90px_1fr] items-center gap-3">
<span class="text-[#8A8F98]">Uptime</span>
<div id="provider-uptime" class="bg-[#232326] border border-white/10 rounded-lg px-3 py-2"></div>
</div>

<div class="grid grid-cols-[90px_1fr] items-center gap-3">
<span class="text-[#8A8F98]">CPU</span>
<div id="provider-cpu" class="bg-[#232326] border border-white/10 rounded-lg px-3 py-2"></div>
</div>

<div class="grid grid-cols-[90px_1fr] items-center gap-3">
<span class="text-[#8A8F98]">GPUs</span>
<div id="provider-gpu" class="bg-[#232326] border border-white/10 rounded-lg px-3 py-2"></div>
</div>

<div class="grid grid-cols-[90px_1fr] items-center gap-3">
<span class="text-[#8A8F98]">Memory</span>
<div id="provider-memory" class="bg-[#232326] border border-white/10 rounded-lg px-3 py-2"></div>
</div>

<div class="grid grid-cols-[90px_1fr] items-center gap-3">
<span class="text-[#8A8F98]">Leases</span>
<div id="provider-leases" class="bg-[#232326] border border-white/10 rounded-lg px-3 py-2"></div>
</div>

</div>

<button id="console-btn" class="mt-6 w-full border border-white/20 rounded-full py-3 hover:bg-[#1f1f22]">
View on Console →
</button>

</div>
</div>

</section>

<script define:vars={{ globeProviders, firstProvider }}>

function bytesToGB(bytes){
  return (bytes / 1024 / 1024 / 1024).toFixed(1)
}

function showProvider(p){

document.getElementById("provider-name").textContent = p.name

document.getElementById("provider-location").textContent =
`${p.region || "Unknown"}${p.country ? ", "+p.country : ""}`

document.getElementById("provider-uptime").textContent =
`${(p.uptime*100).toFixed(2)}%`

document.getElementById("provider-cpu").textContent =
`${p.cpu.active}/${p.cpu.total}`

document.getElementById("provider-gpu").textContent =
`${p.gpu.active}/${p.gpu.total}`

document.getElementById("provider-memory").textContent =
`${bytesToGB(p.memory.active)} / ${bytesToGB(p.memory.total)} GB`

document.getElementById("provider-leases").textContent = p.leases

if(p.audited){
document.getElementById("provider-audited").classList.remove("hidden")
}else{
document.getElementById("provider-audited").classList.add("hidden")
}

document.getElementById("console-btn").onclick = () => {
  window.location.href = `https://console.akash.network/providers/${p.id}`
}

}

window.addEventListener("provider-select", (e) => {
  const selected = globeProviders.find(p => p.id === e.detail)
  if (selected) showProvider(selected)
})

if(firstProvider){
  showProvider(firstProvider)
}

</script>
---
interface Feature {
  icon: string;
  title: string;
  subtitle: string;
  description: string;
}

const features: Feature[] = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M5 5H5.01M5 15H5.01M3 1H17C18.1046 1 19 1.89543 19 3V7C19 8.10457 18.1046 9 17 9H3C1.89543 9 1 8.10457 1 7V3C1 1.89543 1.89543 1 3 1ZM3 11H17C18.1046 11 19 11.8954 19 13V17C19 18.1046 18.1046 19 17 19H3C1.89543 19 1 18.1046 1 17V13C1 11.8954 1.89543 11 3 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "Heavy Iron",
    subtitle: "Enterprise Clusters\nH100 • A100 • A6000...",
    description:
      "High-availability interconnected clusters for massive training runs.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M1 16H19M4 1H16C17.1046 1 18 1.89543 18 3V11C18 12.1046 17.1046 13 16 13H4C2.89543 13 2 12.1046 2 11V3C2 1.89543 2.89543 1 4 1Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "Edge & Inference",
    subtitle: "Consumer Grade\nRTX 4090 • 3090 • 3080...",
    description:
      "Ultra-low cost chips perfect for inference, rendering, and gaming.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M19 10C19 14.9706 14.9706 19 10 19M19 10C19 5.02944 14.9706 1 10 1M19 10H1M10 19C7.689 16.5734 6.4 13.351 6.4 10C6.4 6.64903 7.689 3.42656 10 1M10 19C12.311 16.5734 13.6 13.351 13.6 10C13.6 6.64903 12.311 3.42656 10 1M1 10C1 5.02944 5.02944 1 10 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "The Network",
    subtitle: "Censorship-Resistant\nSovereign Cloud",
    description:
      "No vendor lock-in. No de-platforming. No single point of failure.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M2 13.0002C1.8108 13.0008 1.6252 12.9477 1.4649 12.8471C1.3047 12.7465 1.1762 12.6025 1.0945 12.4318C1.0129 12.2611 0.9813 12.0707 1.0035 11.8828C1.0257 11.6949 1.1008 11.5171 1.22 11.3702L11.12 1.1702C11.1943 1.0844 11.2955 1.0265 11.407 1.0059C11.5185 0.9853 11.6337 1.0032 11.7337 1.0567C11.8337 1.1102 11.9126 1.1961 11.9573 1.3003C12.0021 1.4045 12.0101 1.5208 11.98 1.6302L10.06 7.6502C10.0034 7.8017 9.9844 7.9647 10.0046 8.1252C10.0248 8.2857 10.0837 8.4388 10.1761 8.5716C10.2685 8.7043 10.3918 8.8127 10.5353 8.8873C10.6788 8.962 10.8382 9.0007 11 9.0002H18C18.1892 8.9995 18.3748 9.0526 18.535 9.1532C18.6953 9.2538 18.8238 9.3978 18.9054 9.5685C18.9871 9.7392 19.0187 9.9296 18.9965 10.1175C18.9743 10.3054 18.8992 10.4832 18.78 10.6302L8.88 20.8302C8.8057 20.9159 8.7045 20.9738 8.593 20.9944C8.4815 21.0151 8.3663 20.9972 8.2663 20.9437C8.1663 20.8902 8.0874 20.8043 8.0427 20.7001C7.9979 20.5958 7.9899 20.4795 8.02 20.3702L9.94 14.3502C9.9966 14.1986 10.0156 14.0356 9.9954 13.8752C9.9752 13.7147 9.9163 13.5615 9.8239 13.4287C9.7315 13.296 10.0082 13.1876 10.2647 13.113C10.4212 13.0384 10.1617 12.9996 10 13.0002H2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "Velocity",
    subtitle: "Deployment Speed\n< 60 Seconds",
    description:
      "Time from configuration to first active container.",
  },
];
---

<section class="w-full text-[#171717] dark:text-white py-20 lg:py-[120px]">
  <div class="container-home">

    <div class="text-center mb-16">
      <h2 class="text-[28px] md:font-semibold">
        Permissionless Infrastructure. Unlimited Supply.
      </h2>
      <p class="mt-2 text-[#8A8F98] dark:text-[#8A8F9D] text-base md:text-lg">
        Access a global network of high-<br class="block md:hidden" />performance compute on demand.
      </p>
    </div>

    <div class="flex overflow-x-auto md:grid md:grid-cols-4 gap-12 md:overflow-visible scrollbar-hide">

      {features.map((feature) => (
        <div class="flex min-w-[260px] flex-col gap-4 md:min-w-0">

          <div
            class="flex items-center justify-center h-12 w-12 rounded-lg bg-transparent dark:bg-[#191818] border border-[#E3E3E3] dark:border-[#383838] text-[#171717] dark:text-[#FAFAFA]"
            set:html={feature.icon}
          />

          <div class="space-y-4">
            <h3 class="text-xl font-semibold">
              {feature.title}
            </h3>

            <p class="text-base md:text-lg text-[#171717] dark:text-white whitespace-pre-line">
              {feature.subtitle}
            </p>

            <p class="text-base md:text-lg text-[#8A8F98] dark:text-[#8A8F9D] leading-relaxed max-w-xs">
              {feature.description}
            </p>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>
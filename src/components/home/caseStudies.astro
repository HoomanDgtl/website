---
interface CaseStudy {
  icon: string;
  title: string;
  description: string;
  link: string;
}

const caseStudies: CaseStudy[] = [
  {
    icon: "/images/case-icon-1.svg",
    title:
      "Eliminating Cloud Cost Opacity: How Sigea Cloud Labs Rebuilt Enterprise Storage on Akash",
    description:
      "Sigea Cloud Labs deployed privacy-first cloud storage on Akash Network's decentralized GPU infrastructure.",
    link: "/blog/eliminating-cloud-cost-opacity-how-sigea-cloud-labs-rebuilt-enterprise-storage-on-decentralized-infrastructure",
  },
  {
    icon: "/images/case-icon-2.svg",
    title:
      "Why Levangie Labs Chose Akash to Power the First Semi-Autonomous AI Organization",
    description:
      "Levangie Laboratories built cognitive architecture that enables AI agents to operate independently.",
    link: "/blog/why-levangie-labs-chose-akash-to-power-the-first-semi-autonomous-ai-organization",
  },
  {
    icon: "/images/case-icon-3.svg",
    title:
      "How Flashback Labs Scaled Privacy-First AI on Akash",
    description:
      "Flashback Labs built a privacy-first AI platform that lets users create lifelike AI twins trained entirely on their own data.",
    link: "/blog/how-flashback-labs-scaled-privacy-first-ai-on-akash/",
  },
];
---

<section class="w-full text-white py-20 lg:py-[120px]">
  <div class="container-nav-3">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-[26px] font-semibold">
        Case Studies
      </h2>
      <p class="mt-1 text-[#8A8F98] text-sm">
        The future of DePIN is sovereign, distributed, and builder-owned.
        <br class="hidden md:block"/>
        See how the world's most resilient projects deploy on a global GPU grid that can't be shut down.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      {caseStudies.map((study) => (
        <div class="rounded-[20px] border border-black/10 dark:border-white/10 p-6 flex flex-col h-full">

          <!-- Icon -->
          <div class="w-[48px] h-[48px] flex-shrink-0">
            <img
              src={study.icon}
              alt=""
              width="68"
              height="68"
              loading="lazy"
              decoding="async"
              class="w-full h-full"
            />
          </div>

          <!-- Content -->
          <div class="my-4 md:my-8 space-y-2 flex-grow">
            <h3 class="text-lg font-semibold leading-snug line-clamp-2">
              {study.title}
            </h3>

            <p class="text-sm text-[#7E868C] leading-relaxed line-clamp-2">
              {study.description}
            </p>
          </div>

          <a
            href={study.link}
            class="inline-flex items-center gap-2 rounded-full border border-black/10 dark:border-white/10 px-4 py-2 text-sm text-[#171717] dark:text-white transition-all duration-300 hover:bg-white/30 dark:hover:bg-white/5 w-fit mt-auto"
          >
            <span class="font-medium">Read More</span>

            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              class="transition-transform duration-300 group-hover:translate-x-1"
            >
              <path
                d="M9 6L15 12L9 18"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>

        </div>
      ))}

    </div>

  </div>
</section>

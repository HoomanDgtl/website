---
---

<section
  class="relative w-full h-[80vh] bg-cover bg-center bg-no-repeat"
  style="background-image: url('/images/fuelBgSM.png');"
>
  <style>
    @media (min-width: 768px) {
      section {
        background-image: url('/images/fuelBg.png');
      }
    }
  </style>

  <div class="relative z-10 flex h-full flex-col items-center justify-center py-12 md:py-20 text-center">

    <img
      src="/images/akashstar.svg"
      alt="Akash Star"
      class="h-12 select-none pointer-events-none"
    />

    <div class="my-10 flex flex-col gap-2 md:gap-4 px-6">
      <h2 class="text-[40px] font-semibold leading-[50px] text-white md:text-[64px]">
        AKT: The Fuel Behind Akash
      </h2>

      <p class="text-[#8A8F98] text-base md:text-lg">
        AKT is the utility token that powers every GPU transaction on the
        Akash decentralized cloud.
      </p>
    </div>

    <a
      href="/token/"
      class="flex items-center rounded-lg bg-[#333336] px-4 py-2 text-white transition-all duration-300 hover:brightness-110"
    >
      Learn How AKT Works
    </a>

  </div>
</section>
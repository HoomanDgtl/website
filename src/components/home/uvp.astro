---
import { Server, Monitor, Globe, Zap } from "lucide-react";

const features = [
  {
    icon: "server",
    title: "Heavy Iron",
    description: `Enterprise Clusters\nH100 • A100 • A6000...\n\nHigh-availability interconnected clusters for massive training runs.`,
  },
  {
    icon: "laptop",
    title: "Edge & Inference",
    description: `Consumer Grade\nRTX 4090 • 3090 • 3080...\n\nUltra-low cost chips perfect for inference, rendering, and gaming.`,
  },
  {
    icon: "globe",
    title: "The Network",
    description: `Censorship-Resistant\nSovereign Cloud\n\nNo vendor lock-in. No de-platforming. No single point of failure.`,
  },
  {
    icon: "zap",
    title: "Velocity",
    description: `Deployment Speed\n< 60 Seconds\n\nTime from configuration to first active container.`,
  },
];

const iconMap: Record<string, string> = {
  server: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
  laptop: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>`,
  globe: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  zap: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>`,
};
---

<section class="bg-[#0d0d0e] px-6 py-20 md:px-5 md:py-[120px] xl:px-10">
  <div class="mx-auto max-w-[1397px]">
    <div class="mb-12 flex flex-col items-center gap-3 md:mb-16">
      <h2
        class="max-w-[800px] text-center text-[28px] font-medium leading-tight text-white"
      >
        Permissionless Infrastructure. Unlimited Supply.
      </h2>
      <p class="text-center text-lg text-[#8a8f98]">
        Access a global network of high-performance compute on demand.
      </p>
    </div>

    <div
      class="uvp-scroll -mx-6 flex gap-6 overflow-x-auto px-6 pb-4 sm:mx-0 sm:grid sm:grid-cols-2 sm:gap-8 sm:overflow-visible sm:px-0 sm:pb-0 lg:grid-cols-4"
    >
      {
        features.map((feature) => {
          const lines = feature.description.split("\n");
          const firstTwo = lines.slice(0, 2).join("\n");
          const rest = lines.slice(2).filter(Boolean).join(" ");
          return (
            <div class="flex min-w-[200px] max-w-[280px] shrink-0 flex-col gap-4 sm:min-w-0 sm:max-w-none sm:gap-6">
              <div class="flex flex-col gap-3 sm:gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-[#383838] bg-[#191818] text-white sm:h-12 sm:w-12">
                  <Fragment set:html={iconMap[feature.icon]} />
                </div>
                <h3 class="text-base font-medium text-white sm:text-xl">{feature.title}</h3>
              </div>
              <p class="text-[15px] leading-relaxed sm:text-[17px]">
                <span class="block whitespace-pre-line text-white">
                  {firstTwo}
                </span>
                {rest && <span class="mt-2 block text-[#8c8e91]">{rest}</span>}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .uvp-scroll::-webkit-scrollbar {
    display: none;
  }
  .uvp-scroll {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

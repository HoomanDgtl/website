      url: "/",
    },
  },
  {
    id: 3,
    name: "homenode",
    image: "/images/ecosystem-homepage/homenode.png",
    mobileImage: "/images/ecosystem-homepage/homenode-mob.png",
    title: "Akash Homenode",
    description: "Rent idle compute to developers and earn passive income.",

---
interface Props {
  providerName?: string;
  audited?: boolean;
  location?: string;
  uptime?: string;
  cpu?: string;
  gpus?: string;
  memory?: string;
  leases?: string | number;
}

const {
  providerName = "Foundry Staking",
  audited = true,
  location = "Oslo, Norway 🇳🇴",
  uptime = "100%",
  cpu = "26/26",
  gpus = "8x NVIDIA H100",
  memory = "59GB/198GB",
  leases = "49",
} = Astro.props;

const rows = [
  { label: "Location", value: location },
  { label: "Uptime", value: uptime },
  { label: "CPU", value: cpu },
  { label: "GPUs", value: gpus },
  { label: "Memory", value: memory },
  { label: "Leases", value: String(leases) },
];
---

<div
  class="flex h-full w-full flex-col justify-between rounded-3xl bg-[#242424] p-6"
>
  <!-- Header -->
  <div>
    <div class="mb-1 flex items-start justify-between gap-2">
      <span class="font-sans text-sm text-[#8A8F98]">Provider:</span>
      {
        audited && (
          <span class="flex shrink-0 items-center gap-1.5 rounded-full bg-[#A8F060] px-3 py-1 font-sans text-xs font-semibold text-[#1a1a1a]">
            Audited
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-3.5 w-3.5"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <polyline points="9 12 11 14 15 10" />
            </svg>
          </span>
        )
      }
    </div>
    <h3 class="font-sans text-xl font-bold text-white">{providerName}</h3>
  </div>

  <!-- Spec Rows -->
  <div class="mt-5 flex flex-col gap-2.5">
    {
      rows.map(({ label, value }) => (
        <div class="flex items-center justify-between gap-3">
          <span class="w-[38%] shrink-0 font-sans text-sm font-bold text-white">
            {label}
          </span>
          <div class="flex w-[62%] items-center rounded-xl bg-[#333333] px-3 py-2.5">
            <span class="font-sans text-sm text-[#8A8F98]">{value}</span>
          </div>
        </div>
      ))
    }
  </div>

  <!-- CTA Button -->
  <a
    href="https://console.akash.network/providers"
    target="_blank"
    rel="noopener noreferrer"
    class="mt-6 flex w-full items-center justify-center gap-2 rounded-full bg-[#333333] px-4 py-3.5 font-sans text-sm font-semibold text-white transition-colors hover:bg-[#3d3d3d]"
  >
    View on Console
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-4 w-4"
    >
      <polyline points="9 18 15 12 9 6" />
    </svg>
  </a>
</div>

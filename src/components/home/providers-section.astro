<style>

.globe-wrapper{
height:450px;
max-width:740px;
overflow:hidden;
position:relative;
background:#0e0e0e;
}

#globe{
position:absolute;
width:100%;
height:900px;
bottom:-400px;
left:0;
}

.provider-card{
background:linear-gradient(180deg,#1f1f22 0%,#1a1a1c 100%);
border:1px solid rgba(255,255,255,0.08);
border-radius:24px;
padding:28px;
}

.card-header{
display:flex;
justify-content:space-between;
align-items:flex-start;
margin-bottom:20px;
}

.card-label{
font-size:13px;
color:#8A8F98;
}

.card-provider{
font-size:18px;
margin-top:4px;
}

.audit-pill{
background:#9EF29E;
color:#0c3205;
padding:6px 12px;
border-radius:999px;
font-size:13px;
display:flex;
align-items:center;
gap: 2px;
}

.provider-grid{
display:flex;
flex-direction:column;
gap:14px;
}

.card-row{
display:grid;
grid-template-columns:90px 1fr;
align-items:center;
gap:12px;
font-size:14px;
}

.card-row span{
color:#8A8F98;
}

.value-box{
background:#232326;
border:1px solid rgba(255,255,255,0.08);
border-radius:10px;
padding:10px 12px;
color:#d1d5db;
}

.console-btn{
margin-top:24px;
width:100%;
border:1px solid rgba(255,255,255,0.12);
border-radius:999px;
padding:14px;
background:transparent;
display: flex;
gap: 4px;
justify-content: center;
align-items: center;
}

.console-btn:hover{
background:#1f1f22;
}

/* kill globe.gl wrapper background */
.globe-wrapper .scene-tooltip,
.globe-wrapper .globe-tooltip,
.globe-wrapper .globe-point-label {
  background: transparent !important;
  box-shadow: none !important;
  padding: 0 !important;
}

/* fallback for CSS2DRenderer wrappers */
.globe-wrapper div[style*="position: absolute"] {
  background: transparent !important;
}

.globe-label{
  background:#212124;
  border-radius:16px;
  padding:16px;
  display:flex;
  align-items:center;
  gap:10px;
  color:#fff;
  font-size:14px;
  white-space:nowrap;
}

.globe-label .dot{
  width:12px;
  height:12px;
  border-radius:50%;
  background:#FF2903;
}

.active-label{
  position:absolute;
  top:16px;
  left:16px;
  background:#212124;
  border-radius:16px;
  padding:16px;
  display:flex;
  align-items:center;
  gap:10px;
  color:#fff;
  font-size:14px;
  z-index:10;
}

.active-label .dot{
  width:12px;
  height:12px;
  border-radius:50%;
  background:#FF2903;
}

</style>


<script type="module" define:vars={{points, firstProvider}}>

import Globe from "https://esm.sh/globe.gl"

const container = document.getElementById("globe")

let activeOwner = firstProvider.owner

function bytesToGB(bytes){
  return (bytes / 1024 / 1024 / 1024).toFixed(1)
}

const globe = Globe()(container)

.width(container.clientWidth)
.height(900)

.globeImageUrl("/earth-square.webp")

.backgroundColor("rgba(23,23,23,0)")

.showAtmosphere(false)

.pointOfView({
  lat:50,
  lng:10,
  altitude:1.8
})

.pointsData(points)

.pointAltitude(0.01)

.pointResolution(4)

.pointColor(d =>
  d.owner === activeOwner ? "#FF2903" : "rgba(255,255,255,0.7)"
)

.pointRadius(d =>
  d.owner === activeOwner ? 0.5 : 0.35
)

.pointLabel(d => `
<div class="globe-label">
  <span class="dot"></span>
  ${d.org || d.owner.slice(0,10)}
</div>
`)

.onPointClick(d=>{
activeOwner=d.owner
showProvider(d)
globe.pointsData([...points])
})

function showProvider(p){

document.getElementById("provider-name").textContent =
p.org || p.owner.slice(0,10)

document.getElementById("provider-location").textContent =
`${p.region}, ${p.country}`

document.getElementById("provider-uptime").textContent =
`${(p.uptime*100).toFixed(2)}%`

document.getElementById("provider-cpu").textContent = p.cpu

document.getElementById("provider-gpu").textContent = p.gpu

document.getElementById("provider-memory").textContent =
bytesToGB(p.memory)+" GB"

document.getElementById("provider-leases").textContent =
p.leases

if(p.audited){
document.getElementById("provider-audited").classList.remove("hidden")
}else{
document.getElementById("provider-audited").classList.add("hidden")
}

const label = document.getElementById("active-provider-label")

  label.innerHTML = `
    <span class="dot"></span>
    ${p.org || p.owner.slice(0,10)}
  `

  label.classList.remove("hidden")

document.getElementById("console-btn").onclick = () => {
  window.location.href = `https://console.akash.network/providers/${p.owner}`
}

}

if(firstProvider){
  showProvider(firstProvider)
}

window.addEventListener("resize",()=>{
globe.width(container.clientWidth).height(900)
})

</script>
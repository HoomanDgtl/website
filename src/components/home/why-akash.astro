---
---

<section class="bg-[#0d0d0e] px-5 py-20 md:py-[120px] xl:px-10">
  <div class="mx-auto max-w-[1397px]">
    <div class="mb-12 flex flex-col items-center gap-3 md:mb-14">
      <h2
        class="text-center text-2xl font-medium text-white md:text-[40px] md:leading-tight"
      >
        The Infrastructure for AI & Data
      </h2>
      <p class="text-center text-base text-[#8c8e91] md:text-lg">
        Train, deploy, and scale on the world's most cost-effective
        decentralized cloud.
      </p>
    </div>

    <div class="flex flex-col gap-8 md:gap-10">
      <!-- Row 1 -->
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-10">
        <!-- Train 3x Longer -->
        <div
          class="flex flex-col justify-between gap-8 overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] p-6 md:p-8"
        >
          <div class="flex flex-col gap-5">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              Train 3x Longer
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed text-[#8c8e91]">
              H100s for $1.33/hr vs AWS at $3.93/hr. Get nearly 3 hours of
              compute for the price of 1. Transparent pricing, no hidden fees.
            </p>
          </div>
          <div class="flex flex-col gap-4">
            <div class="relative h-12 w-full overflow-hidden rounded-full bg-[#ff3b30]">
              <div
                class="flex h-full items-center gap-2 px-3"
              >
                <span
                  class="flex-shrink-0 rounded-full bg-white/20 px-2.5 py-1 text-xs font-medium text-white"
                >
                  Akash
                </span>
                <span
                  class="flex-shrink-0 rounded-full bg-[#ff6b63] px-2.5 py-1 text-xs font-medium text-white"
                >
                  $1.33/hr
                </span>
                <div class="flex-1 rounded-r-full bg-[#522624] py-1"></div>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="flex items-center gap-1.5">
                  <div
                    class="h-0 w-0 border-x-[8px] border-b-[14px] border-x-transparent border-b-[#d9d9d9]"
                  >
                  </div>
                  <span class="text-sm text-[#8c8e91]">Others</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <div
                    class="h-0 w-0 border-x-[8px] border-b-[14px] border-x-transparent border-b-[#ff3b30]"
                  >
                  </div>
                  <span class="text-sm text-[#8c8e91]">Akash</span>
                </div>
              </div>
              <span class="text-lg font-medium text-white">3x 🔥</span>
            </div>
          </div>
        </div>

        <!-- Ray Distributed Clusters -->
        <div
          class="flex flex-col justify-between gap-8 overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] p-6 md:p-8"
        >
          <div class="flex flex-col gap-5">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              Ray Distributed Clusters
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed text-[#8c8e91]">
              Scale training instantly. Spin up multi-node Ray clusters to train
              and fine-tune massive models without the DevOps headache.
            </p>
          </div>
          <div class="flex flex-col items-end gap-3">
            <p class="text-lg text-white">Name Your Price</p>
            <div class="flex flex-wrap justify-end gap-3">
              <div class="rounded-full bg-[#0d0d0e] p-2">
                <div
                  class="rounded-full bg-[#18181a] px-4 py-2 text-xs text-white"
                >
                  Ray Cluster Y
                </div>
              </div>
              <div class="rounded-full bg-[#0d0d0e] p-2">
                <div
                  class="rounded-full bg-[#18181a] px-4 py-2 text-xs text-white"
                >
                  Ray Cluster Z
                </div>
              </div>
              <div class="rounded-full bg-[#0d0d0e] p-2">
                <div
                  class="rounded-full bg-[#18181a] px-4 py-2 text-xs text-white"
                >
                  Ray Cluster B
                </div>
              </div>
              <div class="rounded-full bg-[#0d0d0e] p-2">
                <div
                  class="rounded-full bg-[#18181a] px-4 py-2 text-xs text-white"
                >
                  Ray Cluster A
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-10">
        <!-- 1-Click Templates -->
        <div
          class="flex flex-col justify-between gap-8 overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] p-6 md:p-8"
        >
          <div class="flex flex-col gap-5">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              1-Click Templates
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed text-[#8c8e91]">
              Deploy faster. Launch pre-configured environments for Llama 3,
              Mistral, and Stable Diffusion in seconds.
            </p>
          </div>
          <div class="flex items-end justify-center gap-4">
            <div
              class="h-52 w-56 -rotate-3 rounded-md border border-[#59565a] bg-[#464449] p-1.5 shadow-lg md:h-60 md:w-64"
            >
              <div class="h-full rounded bg-[#2a2a2e] p-2">
                <div class="h-2 w-16 rounded bg-[#59565a]"></div>
                <div class="mt-3 h-2 w-24 rounded bg-[#59565a]"></div>
                <div class="mt-2 h-2 w-20 rounded bg-[#59565a]"></div>
                <div class="mt-4 h-6 w-full rounded bg-[#59565a]"></div>
                <div class="mt-2 h-6 w-full rounded bg-[#59565a]"></div>
              </div>
            </div>
            <div
              class="h-52 w-56 rotate-3 rounded-md border border-[#59565a] bg-[#464449] p-1.5 shadow-lg md:h-60 md:w-64"
            >
              <div class="h-full rounded bg-[#2a2a2e] p-2">
                <div class="h-2 w-16 rounded bg-[#59565a]"></div>
                <div class="mt-3 h-2 w-24 rounded bg-[#59565a]"></div>
                <div class="mt-2 h-2 w-20 rounded bg-[#59565a]"></div>
                <div class="mt-4 h-6 w-full rounded bg-[#59565a]"></div>
                <div class="mt-2 h-6 w-full rounded bg-[#59565a]"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Docker Native -->
        <div
          class="flex flex-col justify-between gap-8 overflow-hidden rounded-[20px] border border-[#262a30] bg-[#111212] p-6 md:p-8"
        >
          <div class="flex flex-col gap-5">
            <h3 class="text-xl font-medium text-white md:text-[28px]">
              Docker Native
            </h3>
            <p class="max-w-[614px] text-base leading-relaxed text-[#8c8e91]">
              No refactoring. If it runs in a container, it runs on Akash. Full
              Kubernetes support with zero vendor lock-in.
            </p>
          </div>
          <div class="flex items-end gap-4">
            <div
              class="flex h-52 w-52 items-center justify-center rounded-lg border border-white/10 p-3 md:h-60 md:w-60"
            >
              <svg
                viewBox="0 0 256 185"
                class="h-20 w-28 text-[#2496ED] md:h-28 md:w-36"
                fill="currentColor"
              >
                <path
                  d="M250.716 70.497c-5.227-3.605-17.24-4.912-26.463-3.115-1.218-9.037-6.195-16.896-15.219-23.939l-5.196-3.56-3.554 5.206c-4.53 6.89-6.795 16.478-6.065 24.381.396 3.973 1.63 8.771 4.41 12.206-3.075 1.694-9.128 3.987-17.123 3.832H.508l-.157.927c-.822 4.88-.856 20.142 5.84 31.88 5.108 8.944 13.02 13.43 23.527 13.43 19.79.028 34.498-6.222 46.505-18.675 10.009-10.371 15.042-24.557 18.29-37.34h15.863c6.355 0 11.19-.12 16.31-2.884 3.405-1.828 5.854-4.58 7.523-7.726.566-1.065 1.56-3.595 1.614-3.797l.6-1.865-1.786-1.161zM25.908 97.216h15.372c.739 0 1.34-.597 1.34-1.335V81.81c0-.737-.601-1.336-1.34-1.336H25.909c-.739 0-1.34.599-1.34 1.336V95.88c0 .738.601 1.336 1.34 1.336zm20.533 0h15.372c.74 0 1.34-.597 1.34-1.335V81.81c0-.737-.6-1.336-1.34-1.336H46.441c-.74 0-1.34.599-1.34 1.336V95.88c0 .738.6 1.336 1.34 1.336zm20.832 0h15.373c.74 0 1.34-.597 1.34-1.335V81.81c0-.737-.6-1.336-1.34-1.336H67.273c-.74 0-1.34.599-1.34 1.336V95.88c0 .738.6 1.336 1.34 1.336zm20.534 0h15.372c.74 0 1.34-.597 1.34-1.335V81.81c0-.737-.6-1.336-1.34-1.336H87.807c-.739 0-1.34.599-1.34 1.336V95.88c0 .738.601 1.336 1.34 1.336zm-41.366-20.534h15.372c.74 0 1.34-.598 1.34-1.336V61.276c0-.738-.6-1.337-1.34-1.337H46.441c-.74 0-1.34.599-1.34 1.337v14.07c0 .738.6 1.336 1.34 1.336zm20.832 0h15.373c.74 0 1.34-.598 1.34-1.336V61.276c0-.738-.6-1.337-1.34-1.337H67.273c-.74 0-1.34.599-1.34 1.337v14.07c0 .738.6 1.336 1.34 1.336zm20.534 0h15.372c.74 0 1.34-.598 1.34-1.336V61.276c0-.738-.6-1.337-1.34-1.337H87.807c-.739 0-1.34.599-1.34 1.337v14.07c0 .738.601 1.336 1.34 1.336zm0-20.534h15.372c.74 0 1.34-.598 1.34-1.337V40.74c0-.737-.6-1.336-1.34-1.336H87.807c-.739 0-1.34.599-1.34 1.336v14.072c0 .739.601 1.337 1.34 1.337zm20.533 20.534h15.373c.739 0 1.34-.598 1.34-1.336V61.276c0-.738-.601-1.337-1.34-1.337h-15.373c-.739 0-1.34.599-1.34 1.337v14.07c0 .738.601 1.336 1.34 1.336z"
                ></path>
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <div
                class="rounded-lg border border-white/10 px-3 py-2 text-xs text-white"
              >
                Container App
              </div>
              <div
                class="rounded-lg border border-white/10 px-3 py-2 text-xs text-white"
              >
                Container App
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---

<section class="w-full text-white py-20 lg:py-[120px]">
  <div class="container-home">

    <div class="text-center mb-16">
      <h2 class="text-[28px] font-semibold">
        Permissionless Infrastructure. Unlimited Supply.
      </h2>
      <p class="mt-2 text-[#8A8F98] text-base md:text-lg">
        Access a global network of high-performance compute on demand.
      </p>
    </div>

    <div class="flex overflow-x-auto md:grid md:grid-cols-4 gap-12 md:overflow-visible scrollbar-hide">

      {features.map((feature) => (
        <div class="flex min-w-[260px] flex-col gap-4 md:min-w-0">

          <div
            class="aspect-square w-[48px]"
            set:html={feature.icon}
          />

          <div class="space-y-4">
            <h3 class="text-xl font-semibold">
              {feature.title}
            </h3>

            <p class="text-base md:text-lg text-white whitespace-pre-line">
              {feature.subtitle}
            </p>

            <p class="text-base md:text-lg text-[#8A8F98] leading-relaxed max-w-xs">
              {feature.description}
            </p>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>
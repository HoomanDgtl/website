---
import axios from "axios"
import { BASE_API_URL } from "@/lib/constants"

const API = `${BASE_API_URL}/v1/providers`

type Provider = {
  ipLat: string | null
  ipLon: string | null
  owner: string
  organization?: string
  ipRegion?: string
  ipCountry?: string
  uptime30d: number
  leaseCount: number
  isAudited: boolean
  stats?: {
    cpu?: { active: number; total: number }
    gpu?: { active: number; total: number }
    memory?: { active: number; total: number }
    storage?: { total?: { total: number } }
  }
}

let providers: Provider[] = []

try {
  const res = await axios.get(API)
  providers = res.data
} catch(e) {
  console.error(e)
}

const points = providers
  .filter(p => p.ipLat && p.ipLon)
  .map(p => ({
    lat: Number(p.ipLat),
    lng: Number(p.ipLon),
    owner: p.owner,
    org: p.organization,
    region: p.ipRegion,
    country: p.ipCountry,

    uptime: p.uptime30d ?? 0,
    leases: p.leaseCount ?? 0,

    cpu: {
      active: p.stats?.cpu?.active ?? 0,
      total: p.stats?.cpu?.total ?? 0
    },

    gpu: {
      active: p.stats?.gpu?.active ?? 0,
      total: p.stats?.gpu?.total ?? 0
    },

    memory: {
      active: p.stats?.memory?.active ?? 0,
      total: p.stats?.memory?.total ?? 0
    },

    storage: {
      total: p.stats?.storage?.total?.total ?? 0
    },

    audited: p.isAudited ?? false
  }))

const firstProvider = points[0]

const totalLeases = points.reduce((sum, p) => sum + p.leases, 0)
const totalCPU = points.reduce((sum, p) => sum + p.cpu.total, 0)
const totalGPU = points.reduce((sum, p) => sum + p.gpu.total, 0)
const totalMemoryBytes = points.reduce((sum, p) => sum + p.memory.total, 0)
const totalMemoryTB = (totalMemoryBytes / 1024 / 1024 / 1024 / 1024).toFixed(1)

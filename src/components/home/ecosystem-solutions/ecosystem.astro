    },
  },
  {
    id: 4,
    name: "agents",
    image: "/images/ecosystem-homepage/agents.png",
    mobileImage: "/images/ecosystem-homepage/agents-mob.png",
    title: "Akash Agents",
    description: "Launch autonomous intelligence on the world's first decentralized compute marketplace.",
    button: {
      text: "Open Akash Agents",
      url: "/",
    },
  },
  {
    id: 5,
    name: "console",
    label: "provider",
    image: "/images/ecosystem-homepage/console2.png",
    mobileImage: "/images/ecosystem-homepage/console2-mob.png",
    title: "Akash Provider Console",
    description: "Monetize your servers by joining the network.",
    button: {
      text: "Become a Provider",
      url: "/",
    },
  },
  {
    id: 6,
    name: "starcluster",
    label: "coming-soon",
    image: "/images/ecosystem-homepage/starcluster.png",
    mobileImage: "/images/ecosystem-homepage/starcluster-mob.png",
    title: "Akash Starcluster",
    description: "A planetary-scale mesh of decentralized AI compute designed to democratize access to GPU and CPU resources worldwide",
    button: {
      text: "Coming Soon",
      url: "/",
    },
  },
  {
    id: 7,
    name: "chat",
    image: "/images/ecosystem-homepage/chat.png",
    mobileImage: "/images/ecosystem-homepage/chat-mob.png",
    title: "Akash Chat",
    description: "A live chat app running on Akash Network, showcasing how modern apps run without central servers, powered by global, permissionless infrastructure.",
    button: {
      text: "Open Akash Chat",
      url: "/",
    },
  },
  {
    id: 8,
    name: "gen",
    image: "/images/ecosystem-homepage/gen.png",
    mobileImage: "/images/ecosystem-homepage/gen-mob.png",
    title: "Akash Gen",
    description: "A live “gen” app powered by Akash Network, turning text prompts into high-quality images using distributed GPU compute.",
    button: {
      text: "Open Akash Gen",
      url: "/",
    },
  },
  {
    id: 9,
    name: "stats",
    image: "/images/ecosystem-homepage/stats.png",
    mobileImage: "/images/ecosystem-homepage/stats-mob.png",
    title: "Akash Stats",
    description: "A live dashboard showcasing real-time network activity, deployments, and resource usage, highlighting the scale, transparency, and performance of decentralized cloud infrastructure.",
    button: {
      text: "Open Akash Stats",
      url: "/",
    },
  },
];

const priorityProjects = (await getCollection("Ecosystem_Page"))
  .filter(
    (project) =>
      project.data.category === "deployed_on_akash" &&
      getPriorityIndex(project.data.projectTitle) < deployedOnAkash.length
  )
  .sort(
    (a, b) =>
      getPriorityIndex(a.data.projectTitle) -
      getPriorityIndex(b.data.projectTitle)
  );

const nonPriorityProjects = (await getCollection("Ecosystem_Page"))
  .filter(
    (project) =>
      (project.data.category === "deployed_on_akash" ||
        project.data.category.includes("deployed_on_akash")) &&
      getPriorityIndex(project.data.projectTitle) === deployedOnAkash.length
  )
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() -
      new Date(a.data.pubDate).getTime()
  );

const deployedProjects = [...priorityProjects, ...nonPriorityProjects];
---

<section class="py-20 lg:py-[120px]">
  <div class="container-nav-3 mx-auto">
    <EcosystemTabs
      client:load
      items={ecosystemItems}
      deployedProjects={deployedProjects}
    />
  </div>
</section>